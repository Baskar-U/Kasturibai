# Environment Variables for Kasthuribai E-commerce
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_URL=https://your-api-server.com
VITE_API_TIMEOUT=30000

# Application Settings
VITE_APP_NAME=Kasthuribai
VITE_APP_DESCRIPTION=Premium Fashion & Textiles Store
VITE_APP_URL=https://your-site.netlify.app

# WhatsApp Integration
VITE_WHATSAPP_NUMBER=919876543210
VITE_WHATSAPP_MESSAGE=Hello! I'm interested in your products.

# Analytics (Optional)
VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X
VITE_GTM_ID=GTM-XXXXXXX

# Social Media Links
VITE_FACEBOOK_URL=https://facebook.com/kasthuribai
VITE_INSTAGRAM_URL=https://instagram.com/kasthuribai
VITE_TWITTER_URL=https://twitter.com/kasthuribai

# Contact Information
VITE_CONTACT_EMAIL=info@kasthuribai.com
VITE_CONTACT_PHONE=+91 98765 43210
VITE_CONTACT_ADDRESS=123 Fashion Street, Mumbai, India

# Payment Gateway (if applicable)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_WISHLIST=true

# Development Settings
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=error
