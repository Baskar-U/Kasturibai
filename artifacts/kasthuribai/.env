# Freshdesk (if needed for customer support)
# VITE_FRESHDESK_WIDGET_ID=your_freshdesk_widget_id

# Crisp (if needed for customer support)
# VITE_CRISP_WEBSITE_ID=your_crisp_website_id

# Tawk.to (if needed for customer support)
