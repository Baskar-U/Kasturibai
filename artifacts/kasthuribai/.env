# Environment Variables for Kasthuribai E-commerce
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_URL=http://localhost:8080/api
VITE_API_TIMEOUT=30000

# Application Settings
VITE_APP_NAME=Kasthuribai
VITE_APP_DESCRIPTION=Premium Fashion & Textiles Store
VITE_APP_URL=https://your-site.netlify.app

# WhatsApp Integration
VITE_WHATSAPP_NUMBER=919876543210
VITE_WHATSAPP_MESSAGE=Hello! I'm interested in your products.

# Analytics (Optional)
VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X
VITE_GTM_ID=GTM-XXXXXXX

# Social Media Links
VITE_FACEBOOK_URL=https://facebook.com/kasthuribai
VITE_INSTAGRAM_URL=https://instagram.com/kasthuribai
VITE_TWITTER_URL=https://twitter.com/kasthuribai

# Contact Information
VITE_CONTACT_EMAIL=info@kasthuribai.com
VITE_CONTACT_PHONE=+91 98765 43210
VITE_CONTACT_ADDRESS=123 Fashion Street, Mumbai, India

# Payment Gateway (Razorpay)
# Get your key from https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_SY9uQiNhsalWml
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_WISHLIST=true

# Development Settings
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=error

# Additional Configuration (Optional)

# Google Maps API (if needed for store locator)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase Configuration (if needed)
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
# VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
# VITE_FIREBASE_APP_ID=your_firebase_app_id

# Algolia Search (if needed)
# VITE_ALGOLIA_APP_ID=your_algolia_app_id
# VITE_ALGOLIA_SEARCH_API_KEY=your_algolia_search_api_key
# VITE_ALGOLIA_INDEX_NAME=your_algolia_index_name

# Cloudinary (if needed for image uploads)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# Sentry (if needed for error tracking)
# VITE_SENTRY_DSN=your_sentry_dsn

# Hotjar (if needed for user analytics)
# VITE_HOTJAR_ID=your_hotjar_id
# VITE_HOTJAR_SNIPPET_VERSION=6

# Facebook Pixel (if needed for advertising)
# VITE_FACEBOOK_PIXEL_ID=your_facebook_pixel_id

# Google Ads (if needed for advertising)
# VITE_GOOGLE_ADS_ID=your_google_ads_id

# TikTok Pixel (if needed for advertising)
# VITE_TIKTOK_PIXEL_ID=your_tiktok_pixel_id

# Snapchat Pixel (if needed for advertising)
# VITE_SNAPCHAT_PIXEL_ID=your_snapchat_pixel_id

# Pinterest Tag (if needed for advertising)
# VITE_PINTEREST_TAG_ID=your_pinterest_tag_id

# LinkedIn Insight Tag (if needed for advertising)
# VITE_LINKEDIN_PARTNER_ID=your_linkedin_partner_id

# Twitter Pixel (if needed for advertising)
# VITE_TWITTER_PIXEL_ID=your_twitter_pixel_id

# Microsoft Clarity (if needed for user analytics)
# VITE_CLARITY_PROJECT_ID=your_clarity_project_id

# Lucky Orange (if needed for user analytics)
# VITE_LUCKY_ORANGE_ID=your_lucky_orange_id

# FullStory (if needed for user analytics)
# VITE_FULLSTORY_ORG_ID=your_fullstory_org_id

# LogRocket (if needed for user analytics)
# VITE_LOGROCKET_APP_ID=your_logrocket_app_id

# Amplitude (if needed for user analytics)
# VITE_AMPLITUDE_API_KEY=your_amplitude_api_key

# Mixpanel (if needed for user analytics)
# VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Segment (if needed for user analytics)
# VITE_SEGMENT_WRITE_KEY=your_segment_write_key

# Customer.io (if needed for email marketing)
# VITE_CUSTOMERIO_SITE_ID=your_customerio_site_id
# VITE_CUSTOMERIO_API_KEY=your_customerio_api_key

# Mailchimp (if needed for email marketing)
# VITE_MAILCHIMP_AUDIENCE_ID=your_mailchimp_audience_id
