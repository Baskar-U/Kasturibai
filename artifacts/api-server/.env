# Environment Variables for API Server
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8080
NODE_ENV=development

# Razorpay Configuration
# Get your credentials from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_SY9uQiNhsalWml
RAZORPAY_KEY_SECRET=K6wzlJmzosLlbh6Uxk6Yv4FT

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Database Configuration (if needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT Secret (if needed for authentication)
# JWT_SECRET=your_jwt_secret_here

# Email Configuration (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_email_password

# File Upload Configuration (if needed)
# MAX_FILE_SIZE=5242880
# UPLOAD_DIR=./uploads

# Rate Limiting (if needed)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration (if needed)
# SESSION_SECRET=your_session_secret_here

# Redis Configuration (if needed for caching)
# REDIS_URL=redis://localhost:6379

# AWS Configuration (if needed for S3)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_s3_bucket_name

# Stripe Configuration (if needed)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# PayPal Configuration (if needed)
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_MODE=sandbox

# Twilio Configuration (if needed for SMS)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Google OAuth Configuration (if needed)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth Configuration (if needed)
# FACEBOOK_APP_ID=your_facebook_app_id
# FACEBOOK_APP_SECRET=your_facebook_app_secret

# Apple OAuth Configuration (if needed)
# APPLE_CLIENT_ID=your_apple_client_id
# APPLE_TEAM_ID=your_apple_team_id
# APPLE_KEY_ID=your_apple_key_id
# APPLE_PRIVATE_KEY=your_apple_private_key

# Cloudinary Configuration (if needed for image uploads)
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SendGrid Configuration (if needed for emails)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Firebase Configuration (if needed)
# FIREBASE_PROJECT_ID=your_firebase_project_id
# FIREBASE_PRIVATE_KEY=your_firebase_private_key
# FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Algolia Configuration (if needed for search)
# ALGOLIA_APP_ID=your_algolia_app_id
# ALGOLIA_API_KEY=your_algolia_api_key
# ALGOLIA_INDEX_NAME=your_algolia_index_name

# Sentry Configuration (if needed for error tracking)
# SENTRY_DSN=your_sentry_dsn

# New Relic Configuration (if needed for monitoring)
# NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
# NEW_RELIC_APP_NAME=your_new_relic_app_name

# Datadog Configuration (if needed for monitoring)
# DATADOG_API_KEY=your_datadog_api_key
# DATADOG_APP_KEY=your_datadog_app_key

# Slack Configuration (if needed for notifications)
# SLACK_WEBHOOK_URL=your_slack_webhook_url
# SLACK_CHANNEL=your_slack_channel

# Discord Configuration (if needed for notifications)
# DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Telegram Configuration (if needed for notifications)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# Custom Configuration
# CUSTOM_VARIABLE=your_custom_value
